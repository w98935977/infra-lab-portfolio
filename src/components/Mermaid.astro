---
interface Props {
  chart: string;
}

const { chart } = Astro.props;
---

<pre class="mermaid">{chart}</pre>

<script>
  import mermaid from "mermaid";

  mermaid.initialize({
    startOnLoad: true,
    theme: "dark",
    securityLevel: "strict",
    flowchart: {
      curve: "basis"
    }
  });
</script>
