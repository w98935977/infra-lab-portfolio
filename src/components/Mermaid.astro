---
interface Props {
  chart: string;
}

const { chart } = Astro.props;
---

<div class="diagram-wide">
  <pre class="mermaid">{chart}</pre>
</div>

<script>
  import mermaid from "mermaid";

  mermaid.initialize({
    startOnLoad: true,
    theme: "neutral",
    securityLevel: "strict",
    flowchart: {
      curve: "basis"
    }
  });
</script>
