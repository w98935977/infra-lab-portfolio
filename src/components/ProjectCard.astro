---
interface Props {
  href: string;
  title: string;
  subtitle: string;
  summary: string;
  stack: string[];
  status: string;
}

const { href, title, subtitle, summary, stack, status } = Astro.props;
---

<article class="rounded-lg border border-line bg-white p-6 shadow-sm shadow-slate-200/70">
  <div class="mb-4 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h2 class="text-xl font-semibold text-slate-950">{title}</h2>
      <p class="mt-2 text-sm leading-6 text-slate-600">{subtitle}</p>
    </div>
    <span class="rounded border border-blue-200 bg-blue-50 px-2.5 py-1 text-xs font-medium text-blue-700">
      {status}
    </span>
  </div>
  <p class="text-base leading-7 text-slate-700">{summary}</p>
  <div class="mt-6 flex flex-wrap gap-2">
    {stack.map((item) => (
      <span class="rounded bg-slate-100 px-2.5 py-1 text-xs text-slate-700">{item}</span>
    ))}
  </div>
  <a class="mt-6 inline-flex rounded bg-slate-950 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800" href={href}>
    View case study
  </a>
</article>
