---
interface Props {
  href: string;
  title: string;
  titleZh?: string;
  subtitle: string;
  subtitleZh?: string;
  summary: string;
  summaryZh?: string;
  stack: string[];
  status: string;
  statusZh?: string;
}

const { href, title, titleZh, subtitle, subtitleZh, summary, summaryZh, stack, status, statusZh } = Astro.props;
---

<article class="rounded-lg border border-line bg-white p-6">
  <div class="mb-4 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h2 class="text-xl font-semibold text-ink">
        <span data-lang-content="en">{title}</span>
        <span data-lang-content="zh">{titleZh ?? title}</span>
      </h2>
      <p class="mt-2 text-sm leading-6 text-neutral-600">
        <span data-lang-content="en">{subtitle}</span>
        <span data-lang-content="zh">{subtitleZh ?? subtitle}</span>
      </p>
    </div>
    <span class="rounded border border-green-200 bg-green-50 px-2.5 py-1 text-xs font-medium text-green-700">
      <span data-lang-content="en">{status}</span>
      <span data-lang-content="zh">{statusZh ?? status}</span>
    </span>
  </div>
  <p class="text-base leading-7 text-neutral-700">
    <span data-lang-content="en">{summary}</span>
    <span data-lang-content="zh">{summaryZh ?? summary}</span>
  </p>
  <div class="mt-6 flex flex-wrap gap-2">
    {stack.map((item) => (
      <span class="rounded bg-neutral-100 px-2.5 py-1 text-xs text-neutral-700">{item}</span>
    ))}
  </div>
  <a class="mt-6 inline-flex rounded-full bg-signal px-4 py-2 text-sm font-semibold text-white hover:bg-green-700" href={href}>
    <span data-lang-content="en">View case study</span>
    <span data-lang-content="zh">閱讀案例</span>
  </a>
</article>
