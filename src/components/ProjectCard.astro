---
interface Props {
  href: string;
  title: string;
  subtitle: string;
  summary: string;
  stack: string[];
  status: string;
}

const { href, title, subtitle, summary, stack, status } = Astro.props;
---

<article class="rounded-lg border border-line bg-panel/80 p-5 shadow-xl shadow-black/10">
  <div class="mb-4 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h2 class="text-xl font-semibold text-white">{title}</h2>
      <p class="mt-1 text-sm leading-6 text-slate-300">{subtitle}</p>
    </div>
    <span class="rounded border border-sky-400/40 px-2.5 py-1 text-xs font-medium text-sky-200">
      {status}
    </span>
  </div>
  <p class="text-sm leading-6 text-slate-300">{summary}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    {stack.map((item) => (
      <span class="rounded bg-slate-800 px-2.5 py-1 text-xs text-slate-300">{item}</span>
    ))}
  </div>
  <a class="mt-5 inline-flex rounded bg-sky-400 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-sky-300" href={href}>
    View case study
  </a>
</article>
