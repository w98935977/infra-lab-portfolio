---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} | Infra Lab Portfolio`} description={project.data.summary}>
  <article class="mx-auto max-w-4xl">
    <header class="border-b border-line pb-8">
      <a class="text-sm font-semibold text-sky-300 hover:text-sky-200" href="/projects">Back to projects</a>
      <p class="mt-6 font-mono text-sm uppercase tracking-wider text-slate-400">{project.data.status}</p>
      <h1 class="mt-3 text-4xl font-semibold leading-tight text-white md:text-5xl">{project.data.title}</h1>
      <p class="mt-4 text-lg leading-8 text-slate-300">{project.data.subtitle}</p>
      <div class="mt-6 flex flex-wrap gap-2">
        {project.data.stack.map((item: string) => (
          <span class="rounded bg-slate-800 px-2.5 py-1 text-xs text-slate-300">{item}</span>
        ))}
      </div>
    </header>
    <div class="prose prose-invert mt-8 max-w-none prose-headings:text-white prose-a:text-sky-300 prose-code:text-sky-100 prose-strong:text-white prose-li:marker:text-sky-300">
      <Content />
    </div>
  </article>
</BaseLayout>
