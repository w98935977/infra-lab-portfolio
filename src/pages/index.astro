---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProjectCard from "@components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Infra Lab Portfolio"
  description="Infra / Linux / DevOps lab portfolio focused on production-like troubleshooting, service lifecycle, and operational validation."
>
  <section class="grid gap-12 border-b border-line pb-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div>
      <p class="font-mono text-sm uppercase tracking-wider text-blue-700">Infra / Linux / DevOps Portfolio</p>
      <h1 class="mt-5 max-w-3xl text-4xl font-semibold leading-tight text-slate-950 md:text-6xl">
        Real infrastructure labs, written like engineering case studies.
      </h1>
      <p class="mt-7 max-w-2xl text-xl leading-9 text-slate-700">
        This site documents hands-on Linux and DevOps lab projects: architecture decisions, service lifecycle work, validation commands, production-like failures, and what changed during troubleshooting.
      </p>
      <p class="mt-5 max-w-2xl text-base leading-7 text-slate-600">
        It is designed for interview review and portfolio screening, not generic blog posts.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a class="rounded bg-slate-950 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800" href="/projects">
          Browse projects
        </a>
        <a class="rounded border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-800 hover:bg-white" href="/projects/three-tier-linux-lab">
          Open first lab
        </a>
      </div>
    </div>
    <aside class="rounded-lg border border-line bg-white p-6 shadow-sm shadow-slate-200/70">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">What the site shows</h2>
      <dl class="mt-5 grid gap-4">
        <div>
          <dt class="font-semibold text-slate-950">Service lifecycle</dt>
          <dd class="mt-1 text-sm leading-6 text-slate-600">systemd units, restricted service accounts, environment files, process validation.</dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-950">Operational validation</dt>
          <dd class="mt-1 text-sm leading-6 text-slate-600">health checks, readiness checks, database connectivity, backup and restore proof.</dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-950">Troubleshooting</dt>
          <dd class="mt-1 text-sm leading-6 text-slate-600">documented failures, root causes, and corrective changes.</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="mt-14">
    <div class="mb-5 flex items-end justify-between gap-4">
      <div>
        <h2 class="text-2xl font-semibold text-slate-950">Featured project</h2>
        <p class="mt-2 text-sm text-slate-600">A detailed Linux service and database lab.</p>
      </div>
      <a class="text-sm font-semibold text-blue-700 hover:text-blue-900" href="/projects">All projects</a>
    </div>
    {projects.slice(0, 1).map((project) => (
      <ProjectCard
        href={`/projects/${project.slug}`}
        title={project.data.title}
        subtitle={project.data.subtitle}
        summary={project.data.summary}
        stack={project.data.stack}
        status={project.data.status}
      />
    ))}
  </section>
</BaseLayout>
