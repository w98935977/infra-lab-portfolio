---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProjectCard from "@components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Infra Lab Portfolio"
  description="Infrastructure and Linux systems lab portfolio focused on production-like troubleshooting, service lifecycle, and operational validation."
>
  <section class="grid gap-12 border-b border-line pb-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div>
      <p class="font-mono text-sm uppercase tracking-wider text-signal">Infrastructure / Linux Systems</p>
      <h1 class="mt-5 max-w-3xl text-4xl font-semibold leading-tight text-ink md:text-6xl">
        Real Linux infrastructure labs, written like engineering case studies.
      </h1>
      <p class="mt-7 max-w-2xl text-xl leading-9 text-neutral-700">
        This site documents hands-on systems work: Linux services, reverse proxies, databases, access control, health checks, backup validation, and the troubleshooting path behind each result.
      </p>
      <p class="mt-5 max-w-2xl text-base leading-7 text-neutral-600">
        It is designed for interview review and portfolio screening, not generic blog posts.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a class="rounded-full bg-signal px-4 py-2 text-sm font-semibold text-white hover:bg-green-700" href="/projects">
          Browse projects
        </a>
        <a class="rounded-full border border-neutral-300 px-4 py-2 text-sm font-semibold text-ink hover:border-neutral-500" href="/projects/three-tier-linux-lab">
          Open first lab
        </a>
      </div>
    </div>
    <aside class="rounded-lg border border-line bg-white p-6">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-500">What the site shows</h2>
      <dl class="mt-5 grid gap-4">
        <div>
          <dt class="font-semibold text-ink">Service lifecycle</dt>
          <dd class="mt-1 text-sm leading-6 text-neutral-600">systemd units, restricted service accounts, environment files, process validation.</dd>
        </div>
        <div>
          <dt class="font-semibold text-ink">Operational validation</dt>
          <dd class="mt-1 text-sm leading-6 text-neutral-600">health checks, readiness checks, database connectivity, backup and restore proof.</dd>
        </div>
        <div>
          <dt class="font-semibold text-ink">Troubleshooting</dt>
          <dd class="mt-1 text-sm leading-6 text-neutral-600">documented failures, root causes, and corrective changes.</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="mt-14">
    <div class="mb-5 flex items-end justify-between gap-4">
      <div>
        <h2 class="text-2xl font-semibold text-ink">Featured project</h2>
        <p class="mt-2 text-sm text-neutral-600">A detailed Linux service and database lab.</p>
      </div>
      <a class="text-sm font-semibold text-signal hover:text-green-700" href="/projects">All projects</a>
    </div>
    {projects.slice(0, 1).map((project) => (
      <ProjectCard
        href={`/projects/${project.slug}`}
        title={project.data.title}
        subtitle={project.data.subtitle}
        summary={project.data.summary}
        stack={project.data.stack}
        status={project.data.status}
      />
    ))}
  </section>
</BaseLayout>
