---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Infrastructure and Linux systems lab portfolio." } = Astro.props;
const navItems = [
  { href: "/", label: "Home", labelZh: "首頁" },
  { href: "/projects", label: "Projects", labelZh: "專案" }
];
---

<!doctype html>
<html lang="en" data-language="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const saved = localStorage.getItem("site-language");
        const language = saved === "zh" ? "zh" : "en";
        document.documentElement.dataset.language = language;
        document.documentElement.lang = language === "zh" ? "zh-Hant" : "en";
      })();
    </script>
  </head>
  <body>
    <header class="border-b border-line bg-white/95 backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
        <a href="/" class="font-mono text-sm font-semibold text-ink">infra-lab</a>
        <div class="flex items-center gap-2 text-sm text-neutral-600">
          {navItems.map((item) => (
            <a class="rounded px-3 py-2 hover:bg-neutral-100 hover:text-ink" href={item.href}>
              <span data-lang-content="en">{item.label}</span>
              <span data-lang-content="zh">{item.labelZh}</span>
            </a>
          ))}
          <button
            class="rounded-full border border-neutral-300 px-3 py-1.5 text-xs font-semibold text-ink hover:border-neutral-500"
            type="button"
            data-language-toggle
            aria-label="Switch language"
          >
            <span data-lang-content="en">繁中</span>
            <span data-lang-content="zh">EN</span>
          </button>
        </div>
      </nav>
    </header>
    <main class="mx-auto max-w-6xl px-5 py-10 md:py-14">
      <slot />
    </main>
    <footer class="border-t border-line bg-white px-5 py-8 text-center text-sm text-neutral-500">
      <span data-lang-content="en">Production-like lab notes for infrastructure engineering interviews.</span>
      <span data-lang-content="zh">以接近正式環境的 Linux 基礎設施實作，整理成面試可讀的工程筆記。</span>
    </footer>
    <script is:inline>
      (() => {
        const button = document.querySelector("[data-language-toggle]");
        if (!button) return;

        button.addEventListener("click", () => {
          const current = document.documentElement.dataset.language === "zh" ? "zh" : "en";
          const next = current === "zh" ? "en" : "zh";
          document.documentElement.dataset.language = next;
          document.documentElement.lang = next === "zh" ? "zh-Hant" : "en";
          localStorage.setItem("site-language", next);
        });
      })();
    </script>
  </body>
</html>
